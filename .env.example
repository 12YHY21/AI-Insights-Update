# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_RANK_MODEL=deepseek-v4-flash
# DEEPSEEK_SUMMARY_MODEL=deepseek-v4-pro
# DIGEST_DRY_RUN=false

