# Copy this file to .env for local runs. Never commit .env.
DEEPSEEK_API_KEY=sk-your-key
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your-hook-id

# Optional: only set this when signature verification is enabled for the bot.
FEISHU_WEBHOOK_SECRET=your-signing-secret

